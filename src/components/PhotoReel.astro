---
import { getCollection } from 'astro:content';

const allPhotos  = await getCollection('photos');
const featured   = allPhotos
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

// Duplicate array so the CSS animation loops seamlessly
const reelPhotos = [...featured, ...featured];
const hasPhotos  = featured.length > 0;
---

<section class="photo-reel-section" aria-label="Featured photos">
  <p class="photo-reel-label">Featured Work</p>

  {hasPhotos ? (
    <div class="reel-track" aria-hidden="true">
      {reelPhotos.map((photo, i) => (
        <div class="reel-item" key={i}>
          <img
            src={photo.data.image}
            alt={photo.data.caption || photo.data.title || 'Featured photo by Joshua Leach'}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  ) : (
    <p class="reel-empty">
      Photos will appear here once added — mark any photo as "Featured" in the admin panel to include it.
    </p>
  )}
</section>
