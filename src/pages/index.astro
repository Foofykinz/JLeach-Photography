---
import BaseLayout  from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import settings    from '../data/settings.json';

const tagline = settings.tagline?.trim();
---

<BaseLayout
  title="JLeach Photography"
  description="Photography portfolio of Joshua Leach — portraits, landscapes, storms, animals, and vehicles."
>
  <!-- Split hero: text left, photo right -->
  <div class="split-hero">

    <div class="split-hero-text">
      <p class="split-hero-eyebrow">Photographer · Oklahoma</p>
      <h1 class="split-hero-name">
        <span>Joshua</span>
        <span>Leach</span>
      </h1>
      <div class="split-hero-rule"></div>
      {tagline && <p class="split-hero-tagline">{tagline}</p>}
      <div class="split-hero-actions">
        <a href="/storms" class="btn btn-dark">View Portfolio</a>
        <a href="/about" class="split-hero-link">About Josh <span aria-hidden="true">→</span></a>
      </div>
    </div>

    <!--
      PHOTO: drop a file at /public/images/hero.jpg to set the right-side image.
      Portrait or square orientation works best — a dramatic storm or landscape shot.
    -->
    <div
      class="split-hero-photo"
      style="background-image: url('/images/hero.jpg')"
      role="img"
      aria-label="Hero photo by Joshua Leach"
    >
    </div>

  </div>

  <!-- 3-column category grid -->
  <GalleryGrid />

  <!-- Bio strip -->
  <section class="bio-strip">
    <div class="bio-strip-grid">
      <div class="bio-card">
        <p>
          Hello all! I'm Josh, born and raised in Illinois, now living in Oklahoma.
          A photographer driven by a passion for capturing moments in all their forms—from
          quiet landscapes to raw emotion in portraits. Let the work speak for itself.
        </p>
        <a href="/about" class="read-more">Read more <span aria-hidden="true">→</span></a>
      </div>

      <div class="bio-card bio-card-info">
        <h3>Joshua Leach</h3>
        <p class="location">Oklahoma</p>
        <a href={`mailto:${settings.contactEmail}`} class="contact-email">
          {settings.contactEmail}
        </a>
        <div class="social-links">
          <a href={settings.facebook}  target="_blank" rel="noopener noreferrer">Facebook</a>
          <a href={settings.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>
          <a href={settings.flickr}    target="_blank" rel="noopener noreferrer">Flickr</a>
          <a href={settings.twitter}   target="_blank" rel="noopener noreferrer">X</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
