---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoGrid  from '../components/PhotoGrid.astro';
import { getCollection } from 'astro:content';

const photos = await getCollection('photos', ({ data }) => data.category === 'animals');
---

<BaseLayout
  title="Animals"
  description="Animal photography by Joshua Leach — wildlife in its natural habitat."
>
  <div class="category-page">
    <div class="category-header">
      <h1>Animals</h1>
      <p>Wildlife and animals captured in their natural environment.</p>
    </div>
    <PhotoGrid photos={photos} />
  </div>
</BaseLayout>
