---
import Sidebar from '../components/Sidebar.astro';
import TopBar  from '../components/TopBar.astro';
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
}

const {
  title       = 'JLeach Photography',
  description = 'Photography portfolio of Joshua Leach — portraits, landscapes, storms, animals, and vehicles.',
  ogImage     = '/images/og-default.jpg',
} = Astro.props;

const pageTitle = title === 'JLeach Photography' ? title : `${title} | JLeach Photography`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- Open Graph / social previews -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta name="twitter:card"       content="summary_large_image" />

  <title>{pageTitle}</title>

  <!-- Favicon — replace public/favicon.svg with Josh's actual logo when ready -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Jost:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

  <!-- GLightbox — lightweight lightbox for photo galleries -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/css/glightbox.min.css" />
</head>

<body>
  <Sidebar />

  <div class="page-wrapper">
    <TopBar />
    <main>
      <slot />
    </main>
  </div>

  <!-- GLightbox init -->
  <script src="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/js/glightbox.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // @ts-ignore — GLightbox is loaded via CDN
      if (typeof GLightbox !== 'undefined') {
        GLightbox({
          touchNavigation: true,
          loop:            true,
          autoplayVideos:  false,
          keyboardNavigation: true,
        });
      }
    });
  </script>
</body>
</html>
